@startuml diagrama_geral
left to right direction
skinparam packageStyle rectangle

skinparam nodesep 50
skinparam ranksep 80
skinparam linetype ortho

skinparam usecase {
  BackgroundColor LightCyan
  BorderColor DarkCyan
}

actor "Atendente" as AT
actor "Farmacêutico" as FA
actor "Gerente" as GE

actor "Sistema" as SYS

rectangle "Sistema Saúde & Vida" {
  
  package "Frente de Caixa (PDV)" {
    usecase "UC06 - Realizar Venda a Prazo" as UC06
    usecase "UC09 - Validar Receita" as UC09
    
    usecase "UC01 - Realizar Venda" as UC01
    
    usecase "UC02 - Identificar Cliente" as UC02
    usecase "UC03 - Consultar Produto" as UC03
    usecase "UC05 - Finalizar Operação" as UC05
    usecase "UC04 - Verificar Estoque" as UC04
  }
  
  package "Retaguarda" {
    usecase "UC10 - Cadastrar Produto" as UC10
    usecase "UC07 - Receber Compra" as UC07
    usecase "UC08 - Atualizar Estoque" as UC08
  }
}

AT --> UC01
AT --> UC02
AT --> UC03
AT --> UC05
AT --> UC06

FA --> UC09

GE --> UC10
GE --> UC07

UC06 ..> UC01 : <<extend>>
UC09 ..> UC01 : <<extend>>

UC01 ..> UC02 : <<include>>
UC01 ..> UC03 : <<include>>
UC01 ..> UC04 : <<include>>
UC01 ..> UC05 : <<include>>

UC07 ..> UC08 : <<include>>

UC04 ---> SYS
UC05 ---> SYS
UC08 ---> SYS

@enduml